# Environment Configuration for FIAE Tutor Desktop
# Copy this file to .env and adjust paths for your system

# REQUIRED: Absolute path to the Python core repository
# Example Windows: C:\Projects\fiae-workspace\fiae-tutor
# Example Linux/Mac: /home/user/projects/fiae-workspace/fiae-tutor
FIAE_TUTOR_CORE_DIR=C:\Projects\fiae-workspace\fiae-tutor

# REQUIRED: Python executable to use
# Use 'python' for Windows or 'python3' for Linux/Mac
# Can also be an absolute path like C:\Python311\python.exe
FIAE_TUTOR_PYTHON=python
